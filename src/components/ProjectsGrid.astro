---
import type { Lang } from '@types';
import type { Projects } from '@types';
import { t } from '@utils/i18n';
import ProjectCard from './ProjectCard.astro';
import ProjectFilters from './ProjectFilters.astro';

interface Props {
  projects: Projects;
  lang: Lang;
}
const { projects, lang } = Astro.props;
---

<section id="projects" class="py-20 bg-white dark:bg-slate-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-10">
      <h2 class="section-heading">{t('sections.projects', lang)}</h2>
      <p class="text-slate-500 dark:text-slate-400 text-lg mt-2">
        {t('projects.subtitle', lang)}
      </p>
    </div>

    <!-- Filters -->
    <ProjectFilters projects={projects} lang={lang} />

    <!-- Grid -->
    <div
      id="projects-grid"
      class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8"
    >
      {projects.projects.map((project) => (
        <div class="flex">
          <ProjectCard project={project} lang={lang} />
        </div>
      ))}
    </div>
  </div>
</section>
