---
import type { Lang } from '@types';
import type { Profile } from '@types';
import { t } from '@utils/i18n';

interface Props {
  lang: Lang;
  profile?: Profile;
}
const { lang } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-slate-900 dark:bg-slate-950 text-slate-400 py-12 print:hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Contact section integrated -->
    <section id="contact" class="mb-12">
      <div class="text-center mb-8">
        <h2 class="text-2xl font-bold text-white mb-2">{t('contact.cta_heading', lang)}</h2>
        <p class="text-slate-400 max-w-xl mx-auto">{t('contact.cta_desc', lang)}</p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <!-- Email -->
        <a
          href="mailto:aithammoukarim@gmail.com"
          class="flex items-center gap-3 p-4 rounded-xl bg-slate-800 hover:bg-slate-700 transition-colors group"
        >
          <div class="w-10 h-10 rounded-lg bg-indigo-600/20 flex items-center justify-center flex-shrink-0 group-hover:bg-indigo-600/30 transition-colors">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">{t('contact.email_label', lang)}</p>
            <p class="text-sm text-slate-200 font-medium truncate">aithammoukarim@gmail.com</p>
          </div>
        </a>

        <!-- Phone -->
        <a
          href="tel:+212615807663"
          class="flex items-center gap-3 p-4 rounded-xl bg-slate-800 hover:bg-slate-700 transition-colors group"
        >
          <div class="w-10 h-10 rounded-lg bg-indigo-600/20 flex items-center justify-center flex-shrink-0 group-hover:bg-indigo-600/30 transition-colors">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">{t('contact.phone_label', lang)}</p>
            <p class="text-sm text-slate-200 font-medium">+212 6 15-80-76-63</p>
          </div>
        </a>

        <!-- Location -->
        <div class="flex items-center gap-3 p-4 rounded-xl bg-slate-800">
          <div class="w-10 h-10 rounded-lg bg-indigo-600/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">{t('contact.location_label', lang)}</p>
            <p class="text-sm text-slate-200 font-medium">Rabat, {lang === 'fr' ? 'Maroc' : 'Morocco'}</p>
          </div>
        </div>

        <!-- LinkedIn -->
        <a
          href="https://linkedin.com/in/karimaithammou"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 rounded-xl bg-slate-800 hover:bg-slate-700 transition-colors group"
        >
          <div class="w-10 h-10 rounded-lg bg-indigo-600/20 flex items-center justify-center flex-shrink-0 group-hover:bg-indigo-600/30 transition-colors">
            <svg class="w-5 h-5 text-indigo-400" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          </div>
          <div>
            <p class="text-xs text-slate-500 mb-0.5">{t('contact.linkedin_label', lang)}</p>
            <p class="text-sm text-slate-200 font-medium">karimaithammou</p>
          </div>
        </a>
      </div>

      <!-- Big CTA button -->
      <div class="text-center">
        <a
          href="mailto:aithammoukarim@gmail.com"
          class="inline-flex items-center gap-2 px-8 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-semibold transition-colors shadow-lg shadow-indigo-900/40"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {t('contact.cta_btn', lang)}
        </a>
      </div>
    </section>

    <!-- Divider -->
    <div class="border-t border-slate-800 pt-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4">
        <!-- Brand -->
        <div class="font-bold text-white text-sm">Karim AIT HAMMOU</div>

        <!-- Back to top -->
        <a
          href="#hero"
          class="flex items-center gap-1.5 text-sm hover:text-indigo-400 transition-colors"
          aria-label={t('footer.back_to_top', lang)}
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7" />
          </svg>
          {t('footer.back_to_top', lang)}
        </a>

        <!-- Rights -->
        <p class="text-xs text-slate-500">
          &copy; {year} Karim AIT HAMMOU. {t('footer.rights', lang)}.
          {' '}{t('footer.built_with', lang)}{' '}
          <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-indigo-400 hover:text-indigo-300 transition-colors">
            Astro
          </a>
        </p>
      </div>
    </div>
  </div>
</footer>
