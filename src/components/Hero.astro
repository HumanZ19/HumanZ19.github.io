---
import type { Lang } from '@types';
import type { Profile } from '@types';
import { t, localized } from '@utils/i18n';

interface Props {
  profile: Profile;
  lang: Lang;
}
const { profile, lang } = Astro.props;
const { basics } = profile;
const label = localized(basics.label, lang);
const availability = localized(basics.availability, lang);
const stats = basics.heroStats;
---

<section
  id="hero"
  class="relative min-h-[90vh] flex items-center overflow-hidden bg-gradient-to-br from-slate-50 via-white to-indigo-50 dark:from-slate-900 dark:via-slate-900 dark:to-indigo-950"
>
  <!-- Background decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-indigo-200/30 dark:bg-indigo-900/20 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-purple-200/30 dark:bg-purple-900/20 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Text content -->
      <div class="animate-fadeIn">
        <!-- Greeting -->
        <p class="text-indigo-600 dark:text-indigo-400 font-semibold text-lg mb-3">
          {t('hero.greeting', lang)}
        </p>

        <!-- Name -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-slate-900 dark:text-white leading-tight mb-4">
          {basics.name}
        </h1>

        <!-- Label / Title -->
        <p class="text-xl sm:text-2xl text-indigo-600 dark:text-indigo-400 font-semibold mb-6">
          {label}
        </p>

        <!-- Availability badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-sm font-medium mb-8">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          {availability}
        </div>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4">
          <a
            href="/cv-print/"
            target="_blank"
            rel="noopener"
            class="btn-primary flex items-center gap-2"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            {t('hero.cta_cv', lang)}
          </a>
          <a href="#contact" class="btn-secondary flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            {t('hero.cta_contact', lang)}
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-4 mt-8">
          {basics.profiles.map((profile) => (
            <a
              href={profile.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={profile.network}
              class="text-slate-500 hover:text-indigo-600 dark:text-slate-400 dark:hover:text-indigo-400 transition-colors"
            >
              {profile.network === 'LinkedIn' && (
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                </svg>
              )}
              {profile.network === 'GitHub' && (
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Stats + Photo -->
      <div class="flex flex-col items-center gap-8 animate-slideUp">
        <!-- Profile photo -->
        <div class="relative">
          <div class="w-48 h-48 lg:w-64 lg:h-64 rounded-full overflow-hidden ring-4 ring-indigo-500/30 ring-offset-4 ring-offset-white dark:ring-offset-slate-900 shadow-2xl">
            <img
              src="/images/profile.png"
              alt={`Photo de ${basics.name}`}
              width="256"
              height="256"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          <!-- Decoration dot -->
          <div class="absolute -bottom-2 -right-2 w-10 h-10 bg-indigo-500 rounded-full flex items-center justify-center shadow-lg">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
            </svg>
          </div>
        </div>

        <!-- Stats cards -->
        {stats && (
          <div class="space-y-3 w-full max-w-sm">
            <div class="grid grid-cols-3 gap-3">
              <div class="card text-center py-4">
                <div class="text-2xl font-extrabold text-indigo-600 dark:text-indigo-400">
                  {basics.yearsOfExperience}+
                </div>
                <div class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-tight">
                  {t('hero.stats_years', lang)}
                </div>
              </div>
              <div class="card text-center py-4">
                <div class="text-2xl font-extrabold text-indigo-600 dark:text-indigo-400">
                  {stats.projectsCount}
                </div>
                <div class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-tight">
                  {t('hero.stats_projects', lang)}
                </div>
              </div>
              <div class="card text-center py-4">
                <div class="text-2xl font-extrabold text-indigo-600 dark:text-indigo-400">
                  {stats.maxTeamManaged}
                </div>
                <div class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-tight">
                  {t('hero.stats_team', lang)}
                </div>
              </div>
            </div>
            {(stats.countriesDeployed || stats.legislationsCompliance) && (
              <div class="grid grid-cols-2 gap-3">
                {stats.countriesDeployed && (
                  <div class="card text-center py-4">
                    <div class="text-2xl font-extrabold text-indigo-600 dark:text-indigo-400">
                      {stats.countriesDeployed}
                    </div>
                    <div class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-tight">
                      {t('hero.stats_countries', lang)}
                    </div>
                  </div>
                )}
                {stats.legislationsCompliance && (
                  <div class="card text-center py-4">
                    <div class="text-2xl font-extrabold text-indigo-600 dark:text-indigo-400">
                      {stats.legislationsCompliance}
                    </div>
                    <div class="text-xs text-slate-500 dark:text-slate-400 mt-1 leading-tight">
                      {t('hero.stats_legislations', lang)}
                    </div>
                  </div>
                )}
              </div>
            )}
          </div>
        )}
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce" aria-hidden="true">
    <svg class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
    </svg>
  </div>
</section>
