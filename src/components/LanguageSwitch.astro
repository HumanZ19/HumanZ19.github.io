---
import type { Lang } from '@types';
import { t, getAlternateUrl } from '@utils/i18n';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const targetLang: Lang = lang === 'fr' ? 'en' : 'fr';
const label = lang === 'fr' ? t('lang.switch_to_en', lang) : t('lang.switch_to_fr', lang);
const href = getAlternateUrl(Astro.url, targetLang);
---

<a
  href={href}
  aria-label={label}
  title={label}
  class="flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium text-slate-600 dark:text-slate-300 hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors duration-200 focus:outline-none focus:ring-2 focus:ring-indigo-500"
  hreflang={targetLang}
>
  <span class="text-base leading-none" aria-hidden="true">
    {targetLang === 'en' ? '🇬🇧' : '🇫🇷'}
  </span>
  <span class="hidden sm:inline">{targetLang === 'en' ? 'EN' : 'FR'}</span>
</a>
