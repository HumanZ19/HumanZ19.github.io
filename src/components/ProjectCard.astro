---
import type { Lang } from '@types';
import type { Project } from '@types';
import { t, localized, localizedArray } from '@utils/i18n';
import { getProjectFilterCategory, getStatusColorClass, getProjectGradient, getProjectInitials } from '@utils/helpers';
import ImageWithFallback from './ImageWithFallback.astro';

interface Props {
  project: Project;
  lang: Lang;
}
const { project, lang } = Astro.props;

const title = project.title;
const category = localized(project.category, lang);
const description = localized(project.description, lang);
const status = localized(project.status, lang);
const client = localized(project.client, lang);
const features = localizedArray(project.features, lang);
const filterCategory = getProjectFilterCategory(project);
const statusColor = getStatusColorClass(project.status.en);
const gradient = getProjectGradient(project.id);
const initials = getProjectInitials(project.title);

const hasTestimonial = !!project.testimonial;
const testimonialText = project.testimonial ? localized(project.testimonial.text, lang) : '';
---

<article
  class="card group flex flex-col h-full hover:border-indigo-300 dark:hover:border-indigo-600 hover:shadow-lg transition-all duration-300"
  data-category={filterCategory}
  data-id={project.id}
>
  <!-- Project image / gradient header -->
  <div class="relative -mx-4 -mt-4 mb-4 rounded-t-xl overflow-hidden h-44">
    <ImageWithFallback
      src={project.image ? `/${project.image}` : undefined}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      width={400}
      height={176}
      fallbackText={initials}
      gradient={gradient}
    />
    <!-- Category badge overlay -->
    <div class="absolute top-3 left-3">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-black/50 backdrop-blur-sm text-white text-xs font-medium">
        {category}
      </span>
    </div>
    <!-- Year badge -->
    <div class="absolute top-3 right-3">
      <span class="inline-flex items-center px-2.5 py-1 rounded-full bg-black/50 backdrop-blur-sm text-white text-xs font-medium">
        {project.date}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="flex flex-col flex-1">
    <!-- Title + Status -->
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="font-bold text-slate-900 dark:text-white text-base leading-snug group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
        {title}
      </h3>
      <span class={`flex-shrink-0 text-xs font-semibold px-2 py-0.5 rounded-full ${statusColor}`}>
        {status}
      </span>
    </div>

    <!-- Client -->
    <p class="text-xs text-slate-500 dark:text-slate-400 mb-3 flex items-center gap-1">
      <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
      </svg>
      {client}
    </p>

    <!-- Description -->
    <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed mb-4 flex-1">
      {description}
    </p>

    <!-- Technologies -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {project.technologies.slice(0, 6).map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
      {project.technologies.length > 6 && (
        <span class="tech-tag text-slate-400 dark:text-slate-500">+{project.technologies.length - 6}</span>
      )}
    </div>

    <!-- Features toggle -->
    {features.length > 0 && (
      <details class="group/details">
        <summary class="cursor-pointer text-xs font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 list-none flex items-center gap-1 mb-2 select-none">
          <svg class="w-4 h-4 transition-transform group-open/details:rotate-90" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
          <span class="show-label">{t('projects.show_features', lang)}</span>
        </summary>
        <ul class="mt-2 space-y-1">
          {features.map((f) => (
            <li class="flex items-start gap-1.5 text-xs text-slate-600 dark:text-slate-400">
              <span class="w-1 h-1 rounded-full bg-indigo-400 flex-shrink-0 mt-1.5" aria-hidden="true"></span>
              {f}
            </li>
          ))}
        </ul>
      </details>
    )}

    <!-- Testimonial snippet -->
    {hasTestimonial && (
      <blockquote class="mt-4 pt-4 border-t border-slate-200 dark:border-slate-700 text-xs italic text-slate-500 dark:text-slate-400">
        "{testimonialText.slice(0, 120)}{testimonialText.length > 120 ? '…' : ''}"
        <footer class="mt-1 text-slate-400 dark:text-slate-500 not-italic font-medium">
          — {project.testimonial!.author}
        </footer>
      </blockquote>
    )}
  </div>
</article>
