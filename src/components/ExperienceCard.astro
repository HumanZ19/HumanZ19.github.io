---
import type { Lang } from '@types';
import { t, localized, localizedArray } from '@utils/i18n';

interface Experience {
  company: string;
  position: { fr: string; en: string };
  startDate: string;
  endDate: string;
  summary: { fr: string; en: string };
  highlights: { fr: string[]; en: string[] };
  stack: string[];
}

interface Props {
  experience: Experience;
  lang: Lang;
}
const { experience, lang } = Astro.props;

const position = localized(experience.position, lang);
const summary = localized(experience.summary, lang);
const highlights = localizedArray(experience.highlights, lang);

const startYear = experience.startDate.split('-')[0];
const endYear =
  experience.endDate === 'Present'
    ? t('experience.present', lang)
    : experience.endDate.split('-')[0];

const isActive = experience.endDate === 'Present';
---

<div class="card group hover:border-indigo-300 dark:hover:border-indigo-600 transition-all duration-300 hover:shadow-lg">
  <!-- Header -->
  <div class="flex flex-wrap items-start justify-between gap-3 mb-4">
    <div>
      <h3 class="font-bold text-slate-900 dark:text-white text-lg leading-tight group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
        {position}
      </h3>
      <p class="text-indigo-600 dark:text-indigo-400 font-semibold mt-0.5">
        {experience.company}
      </p>
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      {isActive && (
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 text-xs font-medium">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse" aria-hidden="true"></span>
          {t('experience.present', lang)}
        </span>
      )}
      <span class="text-sm text-slate-500 dark:text-slate-400 bg-slate-100 dark:bg-slate-800 px-3 py-1 rounded-full font-medium">
        {startYear} – {endYear}
      </span>
    </div>
  </div>

  <!-- Summary -->
  <p class="text-slate-600 dark:text-slate-400 text-sm leading-relaxed mb-4">
    {summary}
  </p>

  <!-- Highlights -->
  <ul class="space-y-2 mb-5">
    {highlights.map((highlight) => (
      <li class="flex items-start gap-2 text-sm text-slate-700 dark:text-slate-300">
        <svg class="w-4 h-4 text-indigo-500 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4" />
        </svg>
        {highlight}
      </li>
    ))}
  </ul>

  <!-- Stack tags -->
  <div>
    <p class="text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-2">
      {t('experience.stack_label', lang)}
    </p>
    <div class="flex flex-wrap gap-1.5">
      {experience.stack.map((tech) => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>
  </div>
</div>
