{
  "extends": "astro/tsconfigs/strictest",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@data/*": ["./src/data/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@utils/*": ["./src/utils/*"],
      "@types": ["./src/types/index.ts"],
      "@types/*": ["./src/types/*"],
      "@schemas/*": ["./src/schemas/*"],
      "@styles/*": ["./src/styles/*"]
    }
  }
}
